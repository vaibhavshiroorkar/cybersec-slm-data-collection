# Copy to .env and fill in. .env is gitignored and auto-loaded at startup
# (src/cybersec_slm/core.py via python-dotenv). Shell env vars take precedence.

# --- Actively used by the pipeline ---
# NVD: only raises the CVE feed's rate limit (extraction works without it).
NVD_API_KEY=your_key_here
# GitHub: raises the API rate limit for source enrichment and split scanning.
# The code reads GITHUB_TOKEN. This file used to say GITHUB_API_KEY, which nothing
# reads, so following it left the low anonymous limit in place and looked fine.
GITHUB_TOKEN=your_token_here

# OTX_API_KEY, SHODAN_API_KEY and VIRUSTOTAL_API_KEY were listed here but nothing
# reads them: no reference in src/, tools/ or CI. Removed rather than left to
# imply a VirusTotal integration that does not exist. Binaries in fetched archives
# are reported by ingestion/binscan.py (magic bytes, offline), not submitted
# anywhere.

# SearXNG — used by `cybersec-slm source` (source discovery). Point at a
# self-hosted instance whose settings.yml enables the JSON format
# (search: formats: [html, json]). Defaults to http://localhost:8080 if unset.
SEARXNG_URL=http://localhost:8080

# Kaggle access token (KGAT_...) — required to fetch kaggle-kind sources. The
# kaggle SDK reads this var; it also falls back to ~/.kaggle/access_token.
KAGGLE_API_TOKEN=KGAT_your_token_here

# NVIDIA NIM — only for the dashboard's Q&A agent page (`--extra agent`).
# Get a key at https://build.nvidia.com; leave blank if you don't use the agent.
NVIDIA_API_KEY=
