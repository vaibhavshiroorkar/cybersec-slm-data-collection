# Copy to .env and fill in. .env is gitignored and auto-loaded at startup
# (src/cybersec_slm/core.py via python-dotenv). Shell env vars take precedence.
#
# Real credentials (NVD, GitHub, Kaggle, NVIDIA) now live in
# secrets/credentials.enc.yaml (SOPS + age), not here -- see
# secrets/credentials.yaml.example and docs/security-requirements.md >
# "Secrets management". core.py decrypts that file before it reads .env, so
# .env only needs to carry these if a machine hasn't migrated yet. Precedence
# is: shell env > secrets/credentials.enc.yaml > .env.

# --- Actively used by the pipeline (fallback only -- prefer secrets/credentials.enc.yaml) ---
# NVD: only raises the CVE feed's rate limit (extraction works without it).
NVD_API_KEY=""
OTX_API_KEY =""
SHODAN_API_KEY=""
VIRUSTOTAL_API_KEY=""
GITHUB_API_KEY=""
GITHUB_TOKEN=""
HF_TOKEN=""

# SearXNG — used by `cybersec-slm source` (source discovery). Point at a
# self-hosted instance whose settings.yml enables the JSON format
# (search: formats: [html, json]). Defaults to http://localhost:8080 if unset.
SEARXNG_URL=http://localhost:8080

# Kaggle access token (KGAT_...) — required to fetch kaggle-kind sources. The
# kaggle SDK reads this var; it also falls back to ~/.kaggle/access_token.
KAGGLE_API_TOKEN=""
NVIDIA_API_KEY=""
DATAGOVINDIA_API_KEY=""
