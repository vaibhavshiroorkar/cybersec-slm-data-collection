# Copy to .env and fill in. .env is gitignored and auto-loaded at startup
# (src/cybersec_slm/core.py via python-dotenv). Shell env vars take precedence.
#
# Every credential below is OPTIONAL: a backend without its credential degrades
# to a no-op (and the sourcing engine's circuit breaker retires it) rather than
# failing the run. They raise rate limits and unlock sources.

# --- Sourcing backends (`cybersec-slm source`) ---
# GitHub: a Personal Access Token (classic or fine-grained). GitHub has no
# separate "API key" — the PAT *is* the API credential. Read as GITHUB_TOKEN by
# sourcing/backends/github.py, sourcing/enrich.py and sourcing/backfill.py.
# Unauthenticated search is ~10 req/min, so this matters at scale.
GITHUB_TOKEN=""

# HuggingFace token — raises the datasets API rate limit and reaches gated repos.
HF_TOKEN=""

# Kaggle: the official kaggle SDK reads these TWO variables (or ~/.kaggle/kaggle.json).
# Get them from kaggle.com -> Settings -> API -> "Create New Token".
KAGGLE_USERNAME=""
KAGGLE_KEY=""

# Zenodo — optional; only raises the anonymous rate limit (Zenodo works without it).
ZENODO_TOKEN=""

# data.gov.in (CKAN) API key — used by the `ckan` sourcing backend to page the
# package_search API. Register at data.gov.in to get one. Note: the host is
# unreachable from some networks; if so the circuit breaker retires the backend.
DATAGOVINDIA_API_KEY=""

# SearXNG — the last-resort discovery backend. Point at a self-hosted instance
# whose settings.yml enables the JSON format (search: formats: [html, json]).
# Defaults to http://localhost:8080 if unset.
SEARXNG_URL=http://localhost:8080

# --- Ingestion ---
# NVD: only raises the CVE feed's rate limit (extraction works without it).
NVD_API_KEY=""

# --- Optional / not used by the core pipeline ---
OTX_API_KEY=""
SHODAN_API_KEY=""
VIRUSTOTAL_API_KEY=""
NVIDIA_API_KEY=""

# Rotating-proxy providers (only if you wire one into the crawler).
SCRAPERAPI_API_KEY=""
ZYTE_API_KEY=""
BRIGHTDATA_API_KEY=""
WEBSCRAPING_AI_API_KEY=""
ZENROWS_API_KEY=""
