# Copy this file to secrets/credentials.yaml, fill in real values, then encrypt it:
#   sops -e secrets/credentials.yaml > secrets/credentials.enc.yaml
#   rm secrets/credentials.yaml
#
# Only secrets/credentials.enc.yaml is ever committed. The plaintext
# credentials.yaml is git-ignored (see .gitignore) and the pre-commit hook
# refuses to stage it as a second line of defense.
#
# One block per source/domain -- this is what keeps a single leaked
# credential from being an infra-wide compromise: each integration gets its
# own value, its own env var, and can be rotated/revoked independently of the
# others.
#
#   env         -- the environment variable core.py sets this value into
#   value       -- the actual credential (only in the encrypted file, never here)
#   rotated_at  -- ISO date this credential was last rotated
#   expires_at  -- ISO date it stops working, if the provider supports expiry;
#                  leave null if the provider issues non-expiring credentials
#                  (NVD, Kaggle today) -- rotate those manually on a calendar
#                  reminder instead. See tools/check_credential_expiry.py.

nvd:
  env: NVD_API_KEY
  value: your_key_here
  rotated_at: null
  expires_at: null   # NVD keys don't expire -- rotate manually, e.g. every 90 days

github:
  env: GITHUB_TOKEN
  value: your_token_here
  rotated_at: null
  expires_at: null   # set this if using a fine-grained PAT with an expiration date

kaggle:
  env: KAGGLE_API_TOKEN
  value: KGAT_your_token_here
  rotated_at: null
  expires_at: null

nvidia:
  env: NVIDIA_API_KEY
  value: your_key_here
  rotated_at: null
  expires_at: null
