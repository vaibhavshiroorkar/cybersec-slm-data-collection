# Copy this file to secrets/credentials.yaml, fill in real values, then encrypt
# it IN PLACE (a shell redirect will not match .sops.yaml's path_regex):
#   cp secrets/credentials.yaml secrets/credentials.enc.yaml
#   sops -e -i secrets/credentials.enc.yaml
#   rm secrets/credentials.yaml
#
# Only secrets/credentials.enc.yaml is ever committed.

nvd:
  env: NVD_API_KEY
  value: your_key_here
  rotated_at: null
  expires_at: null   # NVD keys don't expire -- rotate manually, e.g. every 90 days
  # Optional: "rotation_handler" maps to a predefined script in check_credential_expiry.py
  # e.g., "github_app" or omit for manual rotation.
  # rotation_handler: "my_handler"

github:
  env: GITHUB_TOKEN
  value: your_token_here
  rotated_at: null
  expires_at: null   # set this if using a fine-grained PAT with an expiration date

kaggle:
  env: KAGGLE_API_TOKEN
  value: KGAT_your_token_here
  rotated_at: null
  expires_at: null

nvidia:
  env: NVIDIA_API_KEY
  value: your_key_here
  rotated_at: null
  expires_at: null
