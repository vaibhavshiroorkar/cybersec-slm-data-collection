# Environment
.env
.venv
venv

# Credentials — never commit keys (defensive; real creds live in ~/.kaggle, env vars, etc.)
credentials.json
*-credentials.json
service-account*.json
gcp-*.json
kaggle.json
access_token
secrets/

# Python
__pycache__
*.pyc
*.pyo
.pytest_cache
.ruff_cache
*.egg-info
build/
dist/

# Pipeline data — every generated corpus artifact lives under data/
# (raw, clean, final, flagged, dropped, _stages). Regenerated, too large for git.
data/

# Spreadsheets — the curated catalog is sources/Sources.csv (committed); any
# stray .xlsx/.xls export stays out of git.
*.xlsx
*.xls

# fastText language-id model (downloaded locally, or set FASTTEXT_LID_MODEL)
lid.176.ftz
lid.176.bin

# Logs
logs/

# Dashboard's machine-local advanced settings (settings_store); not project data.
pipeline_settings.json

# OS
.DS_Store
Thumbs.db

# uv
.python-version

# Claude Code (editor/tool config, not part of the app)
.claude/

# Streamlit local theme config (machine-local, not part of the app)
.streamlit/
